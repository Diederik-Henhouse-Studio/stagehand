# Browserbase Configuration
BROWSERBASE_API_KEY=bb_your_api_key_here
BROWSERBASE_PROJECT_ID=prj_your_project_id_here
BROWSERBASE_TIMEOUT=60000

# Politeia Configuration
POLITEIA_OUTPUT_DIR=./output
POLITEIA_LOG_LEVEL=info
POLITEIA_MAX_RETRIES=3
POLITEIA_PARALLEL_SESSIONS=false

# Test Configuration
TEST_MONTH=auto
TEST_YEAR=auto
TEST_VERBOSE=false

# Session Configuration
SESSION_KEEP_ALIVE=true
SESSION_RECORD=true
SESSION_SCREENSHOTS=true

# Performance Configuration
MAX_CONCURRENT_SESSIONS=3
PAGE_TIMEOUT=30000
NAVIGATION_TIMEOUT=60000
